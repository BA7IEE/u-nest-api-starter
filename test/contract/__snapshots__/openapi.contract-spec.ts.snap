{
  "CreateUserDto": {
    "properties": {
      "avatarKey": {
        "description": "头像 key",
        "maxLength": 255,
        "type": "string",
      },
      "email": {
        "description": "邮箱(可选,大小写归一化;空字符串视为未填写)",
        "example": "alice@example.com",
        "type": "string",
      },
      "nickname": {
        "description": "昵称",
        "maxLength": 50,
        "type": "string",
      },
      "password": {
        "description": "密码(至少 8 位,需含字母+数字)",
        "format": "password",
        "maxLength": 128,
        "minLength": 8,
        "type": "string",
      },
      "role": {
        "default": "USER",
        "description": "角色;v1 业务 API 永不允许 SUPER_ADMIN;ADMIN 调用时只能创建 USER;不传默认 USER",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "type": "string",
      },
      "username": {
        "description": "用户名(允许字母/数字/下划线/中横线,3-32);service 内统一 trim+lowercase 入库",
        "example": "alice",
        "maxLength": 32,
        "minLength": 3,
        "type": "string",
      },
    },
    "required": [
      "username",
      "password",
    ],
    "type": "object",
  },
  "HealthResponseDto": {
    "properties": {
      "db": {
        "description": "数据库连通状态(仅 /api/health/ready 成功路径返回 up)",
        "enum": [
          "up",
          "down",
        ],
        "example": "up",
        "type": "string",
      },
      "status": {
        "description": "检查通过标识(三端点成功路径恒为 ok)",
        "enum": [
          "ok",
        ],
        "example": "ok",
        "type": "string",
      },
    },
    "required": [
      "status",
    ],
    "type": "object",
  },
  "LoginDto": {
    "properties": {
      "password": {
        "description": "密码(明文,服务端用 bcrypt 比对);此接口刻意不做长度规则校验",
        "example": "YourPassword123",
        "format": "password",
        "type": "string",
      },
      "username": {
        "description": "用户名(允许字母 / 数字 / 下划线 / 中横线,长度 3-32);service 内部统一 trim + lowercase 后用于查询",
        "example": "admin",
        "maxLength": 32,
        "minLength": 3,
        "type": "string",
      },
    },
    "required": [
      "username",
      "password",
    ],
    "type": "object",
  },
  "LoginResponseDto": {
    "properties": {
      "accessToken": {
        "description": "JWT access token,前端拼 Authorization: Bearer <token>",
        "type": "string",
      },
      "expiresIn": {
        "description": "过期时间,原样回传 JWT_EXPIRES_IN 配置值",
        "example": "7d",
        "type": "string",
      },
      "tokenType": {
        "description": "token 类型",
        "example": "Bearer",
        "type": "string",
      },
    },
    "required": [
      "accessToken",
      "tokenType",
      "expiresIn",
    ],
    "type": "object",
  },
  "PageResultDto": {
    "properties": {
      "items": {
        "description": "当前页数据列表;实际元素类型由具体接口指定",
        "items": {
          "type": "array",
        },
        "type": "array",
      },
      "page": {
        "description": "当前页码",
        "example": 1,
        "type": "number",
      },
      "pageSize": {
        "description": "每页数量",
        "example": 20,
        "type": "number",
      },
      "total": {
        "description": "总记录数",
        "example": 0,
        "type": "number",
      },
    },
    "required": [
      "items",
      "total",
      "page",
      "pageSize",
    ],
    "type": "object",
  },
  "ResetUserPasswordDto": {
    "properties": {
      "newPassword": {
        "description": "新密码(至少 8 位,需含字母+数字);管理员重置无需 oldPassword",
        "format": "password",
        "maxLength": 128,
        "minLength": 8,
        "type": "string",
      },
    },
    "required": [
      "newPassword",
    ],
    "type": "object",
  },
  "UpdateMyProfileDto": {
    "properties": {
      "avatarKey": {
        "description": "头像 key",
        "maxLength": 255,
        "type": "string",
      },
      "nickname": {
        "description": "昵称",
        "maxLength": 50,
        "type": "string",
      },
    },
    "type": "object",
  },
  "UpdateUserDto": {
    "properties": {
      "avatarKey": {
        "description": "头像 key",
        "maxLength": 255,
        "type": "string",
      },
      "email": {
        "description": "邮箱;传空字符串视为清空(入库 null)",
        "type": "string",
      },
      "nickname": {
        "description": "昵称",
        "maxLength": 50,
        "type": "string",
      },
    },
    "type": "object",
  },
  "UpdateUserRoleDto": {
    "properties": {
      "role": {
        "description": "目标角色;不允许 SUPER_ADMIN(只有 seed 能创建)",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "example": "ADMIN",
        "type": "string",
      },
    },
    "required": [
      "role",
    ],
    "type": "object",
  },
  "UpdateUserStatusDto": {
    "properties": {
      "status": {
        "description": "目标状态",
        "enum": [
          "ACTIVE",
          "DISABLED",
        ],
        "example": "DISABLED",
        "type": "string",
      },
    },
    "required": [
      "status",
    ],
    "type": "object",
  },
  "UserResponseDto": {
    "properties": {
      "avatarKey": {
        "description": "头像 key",
        "nullable": true,
        "type": "object",
      },
      "createdAt": {
        "description": "创建时间",
        "format": "date-time",
        "type": "string",
      },
      "email": {
        "description": "邮箱",
        "example": "admin@example.com",
        "nullable": true,
        "type": "object",
      },
      "id": {
        "description": "用户主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "lastLoginAt": {
        "description": "最近一次登录时间",
        "nullable": true,
        "type": "object",
      },
      "nickname": {
        "description": "昵称",
        "nullable": true,
        "type": "object",
      },
      "role": {
        "description": "角色",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "example": "USER",
        "type": "string",
      },
      "status": {
        "description": "状态",
        "enum": [
          "ACTIVE",
          "DISABLED",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "username": {
        "description": "用户名(归一化为小写)",
        "example": "admin",
        "type": "string",
      },
    },
    "required": [
      "id",
      "username",
      "role",
      "status",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
}
`;

