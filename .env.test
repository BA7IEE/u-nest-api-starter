# E2E 测试环境配置(提交进仓库,值全部公开)
# 任何修改必须保持以下不变式:
# - DATABASE_URL 必须指向 app_test 测试库,绝不复用开发库 app
# - JWT_SECRET 仅供 test 使用,production 启动校验会拒绝同一字符串
# - SUPER_ADMIN_* 在 APP_ENV=test 下默认值被放行(强校验只禁 production)

APP_ENV=test
# E2E 用 supertest 直连 app.getHttpServer(),不真 listen;
# 此值仅为通过启动强校验(parsePort 要求 1-65535),具体数字无意义,故意避开开发用 3000。
APP_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_test?schema=public
APP_CORS_ORIGIN=http://localhost:5173
ENABLE_SWAGGER=true
JWT_SECRET=test-secret-please-keep-this-string-long-enough-32-chars
JWT_EXPIRES_IN=1h
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=ChangeMe123456
SUPER_ADMIN_EMAIL=

# V1.1 §15.7:E2E 测试期间放宽登录限流,避免单 spec 内多次 loginAs
# (最大 18 次,users-admin-crud)触发 429 误伤已有 137 用例。
# auth-login-throttle.e2e-spec.ts 自身通过临时 process.env 覆盖把 LIMIT 调小到 5 触发限流场景。
# 生产 / 开发默认仍为 5/60(留空 → app.config.ts fallback)。
LOGIN_THROTTLE_LIMIT=50
LOGIN_THROTTLE_TTL_SECONDS=60
